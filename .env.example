############################################
# Backend (FastAPI + LlamaIndex + Supabase)
############################################

# Supabase project URL, e.g. https://xxxx.supabase.co
SUPABASE_URL=

# Supabase Service Role Key (server-side only).
# Used by the backend to access Storage and verify JWT via Supabase Auth API.
# NEVER expose this key to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# DeepSeek API key (OpenAI-compatible LLM HTTP API).
DEEPSEEK_API_KEY=

# SiliconFlow API key (OpenAI-compatible Embeddings HTTP API).
# Used for BAAI/bge-m3 (1024-dim).
SILICONFLOW_API_KEY=

# Supabase Storage bucket for KB document uploads (create this bucket in Supabase; default name below).
KB_DOCUMENTS_BUCKET=kb-documents

# Max upload size per file in bytes (default 20 MiB).
KB_DOCUMENT_MAX_BYTES=20971520

############################################
# Optional / convenience
############################################

# Uvicorn port (if you want to parameterize your runtime)
# PORT=8000

